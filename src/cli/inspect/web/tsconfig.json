{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  // app.js lives in the sibling assets/ tree (which ships); referencing it via ../ is fine.
  "include": ["../assets/app.js", "src/**/*.ts", "test/**/*.ts"]
}
