# Optional: with direnv installed, this activates the dev environment on `cd`
# (run `direnv allow` once). It is inert without direnv. Nix is preferred for a
# fully pinned toolchain; mise is the fallback. See CONTRIBUTING.md for manual setup.

if has nix && [ -f flake.nix ]; then
  watch_file flake.nix flake.lock
  if type use_flake >/dev/null 2>&1; then
    # nix-direnv is installed: cached, fast reloads.
    use flake
  else
    # Stock direnv without nix-direnv: works, just no caching between reloads.
    eval "$(nix --extra-experimental-features 'nix-command flakes' print-dev-env)"
  fi
  
  # source_up_if_exists executes the sourced file from its own directory.
  # Preserve the directory containing this project's .envrc first.
  export WORKTREE_ROOT="$PWD"

  # Optional machine-local policy inherited from the parent.
  source_up_if_exists .envrc.local
elif has mise && [ -f mise.toml ]; then
  # Fallback to mise. Assumes tools are installed (`mise install`); `mise env`
  # only exports PATH/env for them, it does not install.
  watch_file mise.toml
  eval "$(mise env)"
else
  log_status "no nix or mise found — set up the toolchain manually (see CONTRIBUTING.md)"
fi
