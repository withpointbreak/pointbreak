{
  "name": "pointbreak",
  "displayName": "Pointbreak",
  "publisher": "pointbreak",
  "version": "1.0.0",
  "description": "Pointbreak Review companion for Visual Studio Code.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/withpointbreak/pointbreak.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/withpointbreak/pointbreak/issues"
  },
  "homepage": "https://github.com/withpointbreak/pointbreak#readme",
  "engines": {
    "node": ">=20",
    "vscode": "^1.74.0"
  },
  "extensionKind": ["workspace"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:pointbreak.attention",
    "onCommand:pointbreak.refreshAttention",
    "onCommand:pointbreak.capture",
    "onCommand:pointbreak.openAnnotatedDiff",
    "onCommand:pointbreak.openInReview",
    "onCommand:pointbreak.stopInspect",
    "onCommand:pointbreak.addObservationFromSelection"
  ],
  "contributes": {
    "commands": [
      {
        "command": "pointbreak.refreshAttention",
        "title": "Refresh Review",
        "category": "Pointbreak"
      },
      {
        "command": "pointbreak.capture",
        "title": "Capture Current Work",
        "category": "Pointbreak"
      },
      {
        "command": "pointbreak.openAnnotatedDiff",
        "title": "Open Annotated Diff",
        "category": "Pointbreak"
      },
      {
        "command": "pointbreak.openInReview",
        "title": "Open in Review",
        "category": "Pointbreak"
      },
      {
        "command": "pointbreak.stopInspect",
        "title": "Stop Local Review Service",
        "category": "Pointbreak"
      },
      {
        "command": "pointbreak.addObservationFromSelection",
        "title": "Add Observation from Selection",
        "category": "Pointbreak",
        "enablement": "pointbreak.hasSourceReviewContext"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "pointbreak.openInReview",
          "when": "view == pointbreak.attention && (viewItem == pointbreak.revision || viewItem == pointbreak.attentionItem)",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pointbreak",
          "title": "Pointbreak",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "pointbreak": [
        {
          "id": "pointbreak.attention",
          "name": "Review"
        }
      ]
    },
    "configuration": {
      "title": "Pointbreak",
      "properties": {
        "pointbreak.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a shore CLI binary (overrides the bundled one)."
        },
        "pointbreak.useGlobalCli": {
          "type": "boolean",
          "default": false,
          "description": "Resolve the shore CLI from PATH instead of the bundled binary."
        },
        "pointbreak.reviewUrl": {
          "type": "string",
          "scope": "resource",
          "default": "",
          "description": "Optional URL for an externally managed Pointbreak Review server for this folder."
        },
        "pointbreak.observationTrack": {
          "type": "string",
          "scope": "resource",
          "default": "human:local",
          "description": "Track used for observations added from a source selection."
        }
      }
    }
  },
  "scripts": {
    "format-check": "biome check ./src ./test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "check": "npm run format-check && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "26.0.1",
    "@types/vscode": "1.74.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "happy-dom": "20.10.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
